# OS files
.DS_Store
Thumbs.db

# Runtime inputs, outputs, and log files that shouldn't be tracked in Git.
# Note: Existing files in these folders will continue to be tracked by Git unless explicitly unstaged.
input/*.csv
!input/.gitkeep
output/*.json
!output/.gitkeep
processed/*.csv
!processed/.gitkeep
failed/*.csv
!failed/.gitkeep
logs/*.log
logs/*.csv
!logs/.gitkeep
metadata/processed-files.csv
